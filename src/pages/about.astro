---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

const metadata = {
  title: '運営会社概要',
};

const companyTable = [
  { item: '社名', value: '株式会社キラック' },
  { item: '法人番号', value: '8040001139883' },
  { item: '所在地', value: '千葉県長生郡一宮町一宮9264-11' },
  { item: '設立', value: '2025年7月' },
  { item: '代表者', value: '代表取締役　志田 麻記' },
  {
    item: '事業内容',
    value:
      '中古美容医療機器のAIマッチングプラットフォーム事業、中古トラックのAIマッチングプラットフォーム運営、新規事業開発支援など',
  },
  { item: '取引銀行', value: '房総信用組合 一宮支店' },
  { item: '顧問税理士', value: '千代田法務会計事務所' },
];
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="運営会社概要"
    image={{
      src: '~/assets/images/about-hero.png',
      alt: '医療従事者とビジネスパーソンの相談',
    }}
  >
    <Fragment slot="title">
      中古取引の透明性と安全性を <br />
      <span class="text-accent dark:text-white">あらゆる分野で加速する</span>
    </Fragment>

    <Fragment slot="subtitle">
      株式会社キラックは、中古トラックのAIマッチング「トラックマッチ」中古美容医療機器のAIマッチング「クリニックマッチ」を提供する中古取引の透明性と安全性を、AIによる網羅力で高める中古流通改革企業です。
      <br />
      その他にオンライン診療のプラットフォーム開発等、様々な新規事業に挑戦しています。
    </Fragment>
  </Hero>

  <!-- 会社概要 ******************* -->

  <WidgetWrapper containerClass="max-w-4xl mx-auto">
    <div class="mb-8 md:mx-auto md:mb-10 text-center">
      <h2
        class="text-base text-secondary dark:text-blue-200 font-bold tracking-wide uppercase"
      >
        会社概要
      </h2>
    </div>
    <div class="overflow-x-auto -mx-4 px-4 md:mx-0 md:px-0">
      <table
        class="w-full min-w-[480px] border-collapse border border-slate-200 dark:border-slate-600 rounded-lg overflow-hidden"
      >
        <thead>
          <tr>
            <th
              class="bg-slate-100 dark:bg-slate-800 font-bold text-left py-3 px-4 border-b border-slate-200 dark:border-slate-600 w-36 md:w-40"
            >
              項目
            </th>
            <th
              class="bg-slate-100 dark:bg-slate-800 font-bold text-left py-3 px-4 border-b border-slate-200 dark:border-slate-600"
            >
              概要
            </th>
          </tr>
        </thead>
        <tbody>
          {companyTable.map(({ item, value }) => (
            <tr class="border-b border-slate-200 dark:border-slate-600 last:border-b-0">
              <td class="py-3 px-4 border-r border-slate-200 dark:border-slate-600 font-medium text-slate-700 dark:text-slate-300 align-top">
                {item}
              </td>
              <td class="py-3 px-4 text-slate-600 dark:text-slate-400 align-top">{value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </WidgetWrapper>

  <!-- Features2 Widget ************** -->

  <Features2
    title="フォームまたはLINE"
    tagline="お問い合わせ"
    columns={2}
    items={[
      {
        title: 'フォームでお問い合わせ',
        description:
          'フォームでお問い合わせ頂いた内容はプライバシーポリシーに基づき厳格な個人情報管理の元、1営業日以内を目安にご回答差し上げます。',
        icon: 'tabler:forms',
        href: '#',
      },
      {
        title: 'LINEでお問い合わせ',
        description:
          'クリニックマッチのLINE公式アカウントにて専門スタッフとチャットにてご相談できます。1営業日以内を目安にご返信差し上げます。',
        icon: 'tabler:brand-line',
        href: '#',
      },
    ]}
  />
</Layout>
