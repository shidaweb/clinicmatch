---
import Layout from '~/layouts/PageLayout.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

export const prerender = true;
---

<Layout metadata={{ title: '送信完了（購入希望）' }}>
  <WidgetWrapper containerClass="max-w-2xl mx-auto">
    <div class="rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 p-8 text-center">
      <h1 class="text-2xl md:text-3xl font-bold font-heading text-slate-900 dark:text-white mb-4">送信完了</h1>
      <p class="text-slate-700 dark:text-slate-300 mb-6">
        購入希望フォームを受け付けました。通常1営業日以内にご連絡します。
      </p>
      <a
        href="https://lin.ee/vepVhWc"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full px-6 py-3 text-white font-semibold transition-opacity hover:opacity-90"
        style="background-color: #06C755;"
      >
        LINEで友だち追加
      </a>
    </div>
  </WidgetWrapper>
</Layout>
