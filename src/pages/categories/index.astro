---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { getPermalink, getHomePermalink } from '~/utils/permalinks';

export const prerender = true;

const categories = await getCollection('categories');
const sorted = categories.sort((a, b) => a.data.title.localeCompare(b.data.title, 'ja'));

const metadata = {
  title: '取扱機器カテゴリ',
  description:
    '美容医療機器の取扱カテゴリ一覧。脱毛機・ピコレーザー・IPL・HIFU・RF・痩身機器など、中古売買の対象機種と確認ポイントをご案内します。',
};
---

<Layout metadata={metadata}>
  <WidgetWrapper containerClass="max-w-5xl mx-auto">
    <header class="mb-8 md:mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading text-default">
        取扱機器カテゴリ
      </h1>
      <p class="mt-3 text-xl text-muted dark:text-slate-400 max-w-2xl mx-auto">
        中古売買の対象となる機器カテゴリと、主な機種・購入時の確認ポイントをご紹介します。
      </p>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sorted.map((entry) => {
        const { data } = entry;
        const slug = entry.id.replace(/\.mdx?$/, '');
        const href = getPermalink(`categories/${slug}`);
        const machineNames = data.machines.map((m) => m.name).join('、');
        return (
          <a
            href={href}
            class="block p-5 rounded-xl border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-800 shadow-sm hover:shadow-md hover:border-primary/30 dark:hover:border-primary/40 transition-all"
          >
            <span
              class="inline-block px-2.5 py-0.5 text-xs font-medium rounded text-white"
              style={{ backgroundColor: data.accentColor }}
            >
              {data.title}
            </span>
            <h2 class="mt-2 text-lg font-bold font-heading text-default">{data.title}の中古売買</h2>
            <p class="mt-2 text-sm text-muted dark:text-slate-400 line-clamp-2">{data.description}</p>
            <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
              <span class="font-medium text-slate-700 dark:text-slate-400">主な機種:</span> {machineNames}
            </p>
            <p class="mt-2 text-sm text-primary font-medium">詳細を見る →</p>
          </a>
        );
      })}
    </div>
  </WidgetWrapper>
</Layout>
