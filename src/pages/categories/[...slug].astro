---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Button from '~/components/ui/Button.astro';
import { getPermalink, getHomePermalink } from '~/utils/permalinks';
import type { MetaData } from '~/types';

export const prerender = true;

export const getStaticPaths = (async () => {
  const categories = await getCollection('categories');
  return categories.map((entry) => {
    const slug = entry.id.replace(/\.mdx?$/, '');
    return { params: { slug }, props: { entry } };
  });
}) satisfies GetStaticPaths;

type Props = { entry: Awaited<ReturnType<typeof getCollection<'categories'>>>[number] };
const { entry } = Astro.props;
const { data } = entry;
const categorySlug = entry.id.replace(/\.mdx?$/, '');

const allCases = await getCollection('cases');
const categoryCases = allCases
  .filter((c) => c.data.category === categorySlug)
  .sort((a, b) => new Date(b.data.transactionDate).getTime() - new Date(a.data.transactionDate).getTime());

function formatDateYMD(ym: string): string {
  if (!ym || ym.length < 6) return ym;
  const y = ym.slice(0, 4);
  const m = ym.slice(5, 7);
  return `${y}年${parseInt(m, 10)}月`;
}

const metadata: MetaData = {
  title: `${data.title}の中古売買`,
  description: data.description,
};

const FORM_BUY = getPermalink('contact/buy');
const FORM_SELL = getPermalink('contact/sell');
---

<Layout metadata={metadata}>
  <WidgetWrapper containerClass="max-w-4xl mx-auto">
    <!-- パンくず: トップ > 取扱機器 > [カテゴリ名] -->
    <nav class="mb-6 text-sm text-muted dark:text-slate-400" aria-label="パンくず">
      <ol class="flex flex-wrap items-center gap-1">
        <li><a href={getHomePermalink()} class="hover:text-primary">トップ</a></li>
        <li aria-hidden="true"> &gt; </li>
        <li><a href={getPermalink('categories')} class="hover:text-primary">取扱機器</a></li>
        <li aria-hidden="true"> &gt; </li>
        <li class="text-default font-medium" aria-current="page">{data.title}</li>
      </ol>
    </nav>

    <article>
      <header class="mb-8">
        <span
          class="inline-block px-2.5 py-0.5 text-xs font-medium rounded text-white"
          style={{ backgroundColor: data.accentColor }}
        >
          {data.title}
        </span>
        <h1 class="mt-2 text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading text-default">
          {data.title}の中古売買
        </h1>
        <p class="mt-4 text-lg text-muted dark:text-slate-400">{data.description}</p>
      </header>

      <!-- 主な取扱機種 -->
      <section class="mb-10" aria-labelledby="machines-heading">
        <h2 id="machines-heading" class="text-2xl font-bold font-heading text-default mb-4">主な取扱機種</h2>
        <ul class="grid gap-3 sm:grid-cols-2">
          {data.machines.map((m) => (
            <li class="flex items-baseline gap-2 p-3 rounded-lg bg-slate-50 dark:bg-slate-800/50">
              <span class="font-medium text-default">{m.name}</span>
              <span class="text-sm text-muted dark:text-slate-400">{m.manufacturer}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- 中古購入で確認すべきポイント -->
      <section class="mb-10" aria-labelledby="checkpoints-heading">
        <h2 id="checkpoints-heading" class="text-2xl font-bold font-heading text-default mb-4">
          中古購入で確認すべきポイント
        </h2>
        <ul class="space-y-2">
          {data.checkpoints.map((item) => (
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">✓</span>
              <span class="text-slate-700 dark:text-slate-300">{item}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- 取引事例 -->
      {categoryCases.length > 0 && (
        <section class="mb-10" aria-labelledby="cases-heading">
          <h2 id="cases-heading" class="text-2xl font-bold font-heading text-default mb-4">取引事例</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {categoryCases.map((caseEntry) => {
              const caseSlug = caseEntry.id.replace(/\.mdx?$/, '');
              const caseHref = getPermalink(`cases/${caseSlug}`);
              const caseData = caseEntry.data;
              return (
                <a
                  href={caseHref}
                  class="block p-4 rounded-xl border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-800 hover:border-primary/30 dark:hover:border-primary/40 transition-colors"
                >
                  <h3 class="font-bold font-heading text-default">{caseData.title}</h3>
                  <dl class="mt-2 text-sm text-muted dark:text-slate-400 space-y-0.5">
                    <div class="flex justify-between">
                      <dt>製造</dt>
                      <dd>{formatDateYMD(caseData.manufacturedDate)}</dd>
                    </div>
                    <div class="flex justify-between">
                      <dt>取引時期</dt>
                      <dd>{formatDateYMD(caseData.transactionDate)}</dd>
                    </div>
                  </dl>
                  <p class="mt-2 text-sm text-primary font-medium">詳細を見る →</p>
                </a>
              );
            })}
          </div>
        </section>
      )}

      <!-- CTA -->
      <section class="pt-8 border-t border-slate-200 dark:border-slate-600" aria-labelledby="cta-heading">
        <h2 id="cta-heading" class="text-xl font-bold font-heading text-default mb-4">
          この機器の購入・売却をご検討の方
        </h2>
        <p class="text-muted dark:text-slate-400 mb-6">
          {data.title}の中古購入・売却について、条件の整理からマッチングまでサポートします。お気軽にご相談ください。
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href={FORM_SELL} variant="primary">
            この機器を売却したい
          </Button>
          <Button href={FORM_BUY} variant="secondary">
            この機器の購入を相談する
          </Button>
        </div>
      </section>
    </article>
  </WidgetWrapper>
</Layout>
