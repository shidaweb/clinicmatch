---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import merge from 'lodash.merge';
import type { ImageMetadata } from 'astro';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';

import { getCanonical, getPermalink, getHomePermalink, getBlogPermalink } from '~/utils/permalinks';
import { getStaticPathsBlogPost, blogPostRobots } from '~/utils/blog';
import { findImage } from '~/utils/images';
import type { MetaData } from '~/types';
import ArticleFooter from '~/components/blog/ArticleFooter.astro';
import Breadcrumb from '~/components/seo/Breadcrumb.astro';
import BlogPostingJsonLd from '~/components/seo/BlogPostingJsonLd.astro';

export const prerender = true;

export const getStaticPaths = (async () => {
  return await getStaticPathsBlogPost();
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props as Props;

const url = getCanonical(getPermalink(post.permalink, 'post'));
const image = (await findImage(post.image)) as ImageMetadata | string | undefined;

const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: {
      index: blogPostRobots?.index,
      follow: blogPostRobots?.follow,
    },
    openGraph: {
      type: 'article',
      ...(image
        ? { images: [{ url: image, width: (image as ImageMetadata)?.width, height: (image as ImageMetadata)?.height }] }
        : {}),
    },
  },
  { ...(post?.metadata ? { ...post.metadata, canonical: post.metadata?.canonical || url } : {}) }
) as MetaData;
---

<Layout metadata={metadata}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-6">
    <Breadcrumb
      items={[
        { name: 'トップ', url: getHomePermalink() },
        { name: 'ブログ', url: getBlogPermalink() },
        ...(post.category ? [{ name: post.category.title, url: getPermalink(post.category.slug, 'category') }] : []),
        { name: post.title },
      ]}
    />
  </div>
  <BlogPostingJsonLd
    title={post.title}
    description={post.excerpt}
    url={url}
    publishDate={post.publishDate}
    updateDate={post.updateDate}
    author={post.author}
    image={image}
  />
  <SinglePost post={{ ...post, image: image }} url={url}>
    {post.Content ? <post.Content /> : <Fragment set:html={post.content || ''} />}
  </SinglePost>
  <ToBlogLink />
  <ArticleFooter post={post} />
</Layout>
