---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'お問い合わせ',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Contact" title="お問い合わせ" />

  <section id="form" class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <!-- type 未指定: 購入／売却のフォームを選んでもらう -->
    <div id="form-choice" class="form-panel text-center">
      <p class="text-muted dark:text-slate-400 mb-6">ご希望のフォームをお選びください。</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={getPermalink('contact/buy')}
          class="btn btn-primary inline-block py-3 px-6 rounded-full"
        >
          購入希望フォーム
        </a>
        <a
          href={getPermalink('contact/sell')}
          class="btn btn-secondary inline-block py-3 px-6 rounded-full border"
        >
          売却希望フォーム
        </a>
      </div>
    </div>

    <!-- ?type=buy: 購入希望フォームへ誘導 -->
    <div id="form-buy" class="form-panel hidden text-center">
      <div class="mb-4">
        <a href={getPermalink('contact')} class="text-primary hover:underline">← フォームを選び直す</a>
      </div>
      <h2 class="text-xl font-bold mb-4">購入希望のお問い合わせ</h2>
      <p class="text-muted dark:text-slate-400 mb-6">購入希望フォームは以下のページでご利用いただけます。</p>
      <a href={getPermalink('contact/buy')} class="btn btn-primary inline-block py-3 px-6 rounded-full">
        購入希望フォームを開く
      </a>
    </div>

    <!-- ?type=sell: 売却希望フォームへ誘導 -->
    <div id="form-sell" class="form-panel hidden text-center">
      <div class="mb-4">
        <a href={getPermalink('contact')} class="text-primary hover:underline">← フォームを選び直す</a>
      </div>
      <h2 class="text-xl font-bold mb-4">売却希望のお問い合わせ</h2>
      <p class="text-muted dark:text-slate-400 mb-6">売却希望フォームは以下のページでご利用いただけます。</p>
      <a href={getPermalink('contact/sell')} class="btn btn-secondary inline-block py-3 px-6 rounded-full border">
        売却希望フォームを開く
      </a>
    </div>
  </section>

  <script>
    (function () {
      var params = new URLSearchParams(window.location.search);
      var type = (params.get('type') || '').toLowerCase();
      var choice = document.getElementById('form-choice');
      var buy = document.getElementById('form-buy');
      var sell = document.getElementById('form-sell');
      if (!choice || !buy || !sell) return;

      if (type === 'buy') {
        choice.classList.add('hidden');
        buy.classList.remove('hidden');
      } else if (type === 'sell') {
        choice.classList.add('hidden');
        sell.classList.remove('hidden');
      }
    })();
  </script>
</Layout>
