---
import { SITE } from 'astrowind:config';

const verificationIds = Array.from(
  new Set(
    [SITE.googleSiteVerificationId, ...(SITE.googleSiteVerificationIds ?? [])]
      .map((id) => (typeof id === 'string' ? id.trim() : ''))
      .filter(Boolean)
  )
);
---

{
  verificationIds.map((id) => <meta name="google-site-verification" content={id} />)
}
