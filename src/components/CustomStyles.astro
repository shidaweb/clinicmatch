---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* GM クリニックマッチ ロゴカラー: 青 #2299CC / ホバー #1b85b3 / アクセント（コーラル） #F06464 */
    --aw-color-primary: rgb(34 153 204);
    --aw-color-secondary: rgb(27 133 179);
    --aw-color-accent: rgb(240 100 100);

    --aw-color-text-heading: rgb(68 68 68);
    --aw-color-text-default: rgb(68 68 68);
    --aw-color-text-muted: rgb(68 68 68 / 66%);
    --aw-color-bg-page: #f8fafb;

    --aw-color-bg-page-dark: rgb(15 23 42);

    ::selection {
      background-color: #a1e0eb;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(34 153 204);
    --aw-color-secondary: rgb(27 133 179);
    --aw-color-accent: rgb(240 100 100);

    --aw-color-text-heading: rgb(248 250 251);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: #0f172a;

    ::selection {
      background-color: rgb(34 153 204 / 0.35);
      color: rgb(248 250 251);
    }
  }
</style>
