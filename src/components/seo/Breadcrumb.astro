---
import { SITE } from 'astrowind:config';

export interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
const siteUrl = SITE?.site ?? 'https://clinicmatch.org';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    ...(item.url ? { item: new URL(item.url, siteUrl).toString() } : {}),
  })),
};
---

<nav class:list={['text-xs text-slate-500 dark:text-slate-400', className]} aria-label="パンくず">
  <ol class="flex flex-wrap items-center gap-1">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-1">
          {index > 0 && <span aria-hidden="true"> &gt; </span>}
          {item.url ? (
            <a href={item.url} class="hover:text-primary transition-colors">
              {item.name}
            </a>
          ) : (
            <span class="text-slate-700 dark:text-slate-300 font-medium" aria-current="page">
              {item.name}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
