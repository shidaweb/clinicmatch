# Sanity (Headless CMS for blog)
# Copy to .env and set values. For Cloudflare Pages, configure these in Dashboard > Settings > Environment variables.

SANITY_PROJECT_ID=sjwdnh1q
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# Optional: for private/draft content (e.g. restricted datasets)
# SANITY_READ_TOKEN=your_token

# Optional: set to "false" to always fetch from API (e.g. in CI)
# PUBLIC_SANITY_USE_CDN=true

# Fillout フォーム（/contact?type=buy と /contact?type=sell で出し分け）
# 購入: Standard 埋め込み（div + script）。フォーム ID を設定。
# PUBLIC_FILLOUT_FORM_BUY=afCsAehK2qus
# 売却: iframe の src の URL を設定
# PUBLIC_FILLOUT_FORM_SELL=https://form.fillout.com/yyyyy
